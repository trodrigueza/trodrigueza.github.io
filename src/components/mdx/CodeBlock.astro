---
// src/components/mdx/CodeBlock.astro
import Copy from '../icons/Copy.astro';
import Check from '../icons/Check.astro';

interface Props {
  class?: string;
  'data-language'?: string;
}

const { class: className, 'data-language': dataLanguage } = Astro.props;
---

<div class="code-block-container">
  <pre class={className} data-language={dataLanguage}><slot /></pre>
  
  <!-- Copy button -->
  <button
    type="button"
    class="copy-button"
    aria-label="Copy code to clipboard"
  >
    <span class="copy-icon-container" aria-hidden="true">
      <Copy class="copy-icon" />
      <Check class="check-icon" />
    </span>
  </button>
</div>

<!-- Visually hidden aria-live region for screen reader announcements -->
<div class="sr-only copy-announcement" aria-live="polite" aria-atomic="true"></div>

<script>
  // Module-level timer variable
  let resetTimer: number | null = null;

  // Check if clipboard support is available
  function hasClipboardSupport(): boolean {
    return !!(
      (navigator.clipboard && navigator.clipboard.writeText) ||
      document.queryCommandSupported?.('copy')
    );
  }

  // Extract plain text from pre element
  function extractCodeText(preElement: HTMLPreElement): string {
    return preElement.textContent || '';
  }

  // Copy text to clipboard with fallback
  async function copyToClipboard(text: string): Promise<{
    success: boolean;
    method: 'clipboard-api' | 'execCommand' | 'none';
    error?: Error;
  }> {
    // Try Clipboard API first (modern browsers)
    if (navigator.clipboard && navigator.clipboard.writeText) {
      try {
        await navigator.clipboard.writeText(text);
        return { success: true, method: 'clipboard-api' };
      } catch (error) {
        console.warn('Clipboard API failed, trying fallback', error);
        // Fall through to execCommand fallback
      }
    }

    // Fallback to execCommand (older browsers)
    try {
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();

      const success = document.execCommand('copy');
      document.body.removeChild(textarea);

      return {
        success,
        method: success ? 'execCommand' : 'none'
      };
    } catch (error) {
      return { success: false, method: 'none', error: error as Error };
    }
  }

  // Announce message to screen readers
  function announceToScreenReader(message: string): void {
    const announcement = document.querySelector('.copy-announcement');
    if (!announcement) return;

    // Clear previous announcement
    announcement.textContent = '';

    // Use setTimeout to ensure screen readers detect the change
    setTimeout(() => {
      announcement.textContent = message;
    }, 100);
  }

  // Handle copy button click
  function handleCopy(button: HTMLButtonElement, pre: HTMLPreElement): void {
    const text = extractCodeText(pre);

    copyToClipboard(text).then(result => {
      if (result.success) {
        // Show success state
        button.classList.add('success');
        button.setAttribute('aria-label', 'Code copied');
        announceToScreenReader('Code copied to clipboard');

        // Clear existing timer if button clicked again
        if (resetTimer !== null) {
          clearTimeout(resetTimer);
        }

        // Reset after 1000ms
        resetTimer = window.setTimeout(() => {
          // Check if button still exists in DOM
          if (document.contains(button)) {
            button.classList.remove('success');
            button.setAttribute('aria-label', 'Copy code to clipboard');
          }
          resetTimer = null;
        }, 1000);
      } else {
        // Show error state (no visual change, but announce)
        announceToScreenReader('Failed to copy code');
      }
    });
  }

  // Handle keyboard events
  function handleKeydown(event: KeyboardEvent, button: HTMLButtonElement, pre: HTMLPreElement): void {
    // Enter or Space key activates button
    if (event.key === 'Enter' || event.key === ' ') {
      event.preventDefault(); // Prevent space from scrolling
      handleCopy(button, pre);
    }
  }

  // Initialize copy buttons
  function initCopyButtons(): void {
    // Check for clipboard support
    if (!hasClipboardSupport()) {
      console.warn('Clipboard API not supported, copy buttons will not be initialized');
      return;
    }

    // Find all code block containers
    const codeBlocks = document.querySelectorAll('.code-block-container');

    codeBlocks.forEach(container => {
      const button = container.querySelector('.copy-button') as HTMLButtonElement | null;
      const pre = container.querySelector('pre') as HTMLPreElement | null;

      // Guard against missing elements
      if (!button || !pre) {
        console.warn('Code block missing required elements');
        return;
      }

      // Attach event listeners
      button.addEventListener('click', () => handleCopy(button, pre));
      button.addEventListener('keydown', (e) => handleKeydown(e, button, pre));
    });
  }

  // Cleanup on page unload
  window.addEventListener('beforeunload', () => {
    if (resetTimer !== null) {
      clearTimeout(resetTimer);
    }
  });

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCopyButtons);
  } else {
    initCopyButtons();
  }
</script>

<style>
  .code-block-container {
    position: relative;
    margin: 1.5rem 0;
  }

  /* Ensure pre element has proper styling */
  .code-block-container pre {
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
    border-radius: 0.5rem;
  }

  /* Copy button positioning and layout */
  .copy-button {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    min-width: 44px;
    min-height: 44px;
    padding: 0.625rem;
    z-index: 10;
    border: none;
    cursor: pointer;
    border-radius: 0.375rem;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  /* Theme-aware button styling - Light theme */
  :global(html[data-theme="light"]) .copy-button {
    background-color: rgba(243, 244, 246, 0.8); /* bg-gray-100/80 */
    color: rgb(55, 65, 81); /* text-gray-700 */
    backdrop-filter: blur(4px);
  }

  :global(html[data-theme="light"]) .copy-button:hover {
    background-color: rgba(229, 231, 235, 0.9); /* hover:bg-gray-200/90 */
  }

  /* Theme-aware button styling - Dark theme */
  :global(html[data-theme="dark"]) .copy-button {
    background-color: rgba(31, 41, 55, 0.8); /* dark:bg-gray-800/80 */
    color: rgb(209, 213, 219); /* dark:text-gray-300 */
    backdrop-filter: blur(4px);
  }

  :global(html[data-theme="dark"]) .copy-button:hover {
    background-color: rgba(55, 65, 81, 0.9); /* dark:hover:bg-gray-700/90 */
  }

  /* Focus indicator */
  .copy-button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .copy-button {
      transition: none;
    }
  }

  /* Icon container for positioning */
  .copy-icon-container {
    position: relative;
    display: inline-block;
    width: 16px;
    height: 16px;
  }

  /* Icon visibility management */
  .copy-icon,
  .check-icon {
    position: absolute;
    top: 0;
    left: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  /* Default state: show copy icon */
  .copy-icon {
    opacity: 1;
    transform: scale(1);
  }

  .check-icon {
    opacity: 0;
    transform: scale(0.8);
  }

  /* Success state: show check icon */
  .copy-button.success .copy-icon {
    opacity: 0;
    transform: scale(0.8);
  }

  .copy-button.success .check-icon {
    opacity: 1;
    transform: scale(1);
  }

  /* Respect prefers-reduced-motion for icons */
  @media (prefers-reduced-motion: reduce) {
    .copy-icon,
    .check-icon {
      transition: none;
    }
  }

  /* Screen reader only class */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Restore proper backgrounds based on theme */
  :global(html[data-theme="light"]) .code-block-container {
    background-color: #f6f8fa;
    border-radius: 0.5rem;
  }

  :global(html[data-theme="dark"]) .code-block-container {
    background-color: #0d1117;
    border-radius: 0.5rem;
  }

  /* CRITICAL: Override Tailwind prose plugin's code color rules */
  /* The prose plugin sets all code to one color, killing syntax highlighting */
  /* We need MAXIMUM specificity to override it */
  
  /* Shiki generates: style="color:#24292E;--shiki-dark:#F0F3F6" */
  /* - color: is the LIGHT theme color (e.g., #24292E, #D73A49, #005CC5) */
  /* - --shiki-dark: is the DARK theme color (e.g., #F0F3F6, #FF9492, #91CBFF) */
  
  /* Dark theme: Override inline color with --shiki-dark custom property */
  :global(html[data-theme="dark"] .prose) .code-block-container pre.astro-code :global(span[style]) {
    color: var(--shiki-dark) !important;
  }

  /* Light theme: Prevent prose from overriding Shiki's inline colors */
  /* We need to override the prose plugin's color: var(--tw-prose-code) rule */
  :global(html[data-theme="light"] .prose) .code-block-container pre.astro-code :global(span[style]) {
    /* Use revert to go back to the inline style value */
    color: revert !important;
  }
  
  /* Additional override to prevent prose pre code from applying */
  :global(html[data-theme="dark"] .prose) .code-block-container pre.astro-code {
    color: inherit !important;
  }
  
  :global(html[data-theme="light"] .prose) .code-block-container pre.astro-code {
    color: inherit !important;
  }
</style>
