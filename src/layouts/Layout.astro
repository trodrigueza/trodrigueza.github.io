---
import '@fontsource-variable/jetbrains-mono';
interface Props {
  title: string;
}
import "../styles/global.css";
const { title } = Astro.props;

import Header from "../components/Header.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Theme initialization script - MUST be first to prevent FOIT -->
    <script is:inline>
      // Blocking script to prevent flash of incorrect theme (FOIT)
      (function() {
        // Get stored theme from localStorage with error handling
        function getStoredTheme() {
          try {
            return localStorage.getItem('theme');
          } catch (e) {
            console.warn('localStorage unavailable, using system preference');
            return null;
          }
        }
        
        // Get system theme preference
        function getSystemTheme() {
          if (window.matchMedia) {
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          // Fallback to light theme for older browsers
          return 'light';
        }
        
        // Validate theme value
        function getValidTheme(value) {
          if (value === 'light' || value === 'dark') {
            return value;
          }
          return null;
        }
        
        const storedTheme = getStoredTheme();
        const validStoredTheme = getValidTheme(storedTheme);
        const systemTheme = getSystemTheme();
        const theme = validStoredTheme || systemTheme;
        
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    
    <meta name="color-scheme" content="dark light">
    <meta name="theme-color" content="#050505" media="(prefers-color-scheme: dark)">
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- <div class="absolute top-0 z-[-2] h-screen w-screen bg-neutral-950 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]"></div> -->
    <Header />
    <slot />
  </body>
</html>

<style is:global>
  html {
    font-family: 'JetBrains Mono Variable', monospace;
  }
</style>